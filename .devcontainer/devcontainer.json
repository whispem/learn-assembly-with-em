{
  "name": "learn assembly with em",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/asm,type=bind",
  "workspaceFolder": "/asm",
  "customizations": {
    "vscode": {
      "extensions": [
        "13xforever.language-x86-64-assembly"
      ]
    }
  }
}
